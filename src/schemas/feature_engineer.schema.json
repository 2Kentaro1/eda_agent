{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FeatureEngineerOutput",
  "type": "object",
  "required": ["role", "version", "content", "metadata"],
  "properties": {
    "role": { "const": "FEATURE_ENGINEER" },
    "version": { "type": "string" },
    "content": {
      "type": "object",
      "required": ["feature_plan", "code_snippets"],
      "properties": {
        "feature_plan": { "type": "array", "items": { "type": "string" } },
        "code_snippets": { "type": "object" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["timestamp"],
      "properties": {
        "timestamp": { "type": "string" }
      }
    }
  }
}