{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalystOutput",
  "type": "object",
  "required": ["role", "version", "content", "metadata"],
  "properties": {
    "role": {
      "type": "string",
      "enum": ["ANALYST"]
    },
    "version": {
      "type": "string",
      "description": "Analyst スキーマのバージョン"
    },
    "content": {
      "type": "object",
      "required": [
        "business_insights",
        "key_findings",
        "risks",
        "recommendations",
        "modeling_suggestions"
      ],
      "properties": {
        "business_insights": {
          "type": "array",
          "description": "Notebook の EDA 結果から得られたビジネス的洞察",
          "items": { "type": "string" }
        },
        "key_findings": {
          "type": "array",
          "description": "Notebook の EDA 結果から得られた主要な分析結果",
          "items": { "type": "string" }
        },
        "risks": {
          "type": "array",
          "description": "EDA 結果から判明したリスクや注意点",
          "items": { "type": "string" }
        },
        "recommendations": {
          "type": "array",
          "description": "次ラウンドで EDA Agent が深掘りすべき新しい提案（EDA 視点のみ）",
          "items": { "type": "string" }
        },
        "modeling_suggestions": {
          "type": "array",
          "description": "モデル学習に関する提案（EDA とは別 key）",
          "items": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["notebook_path", "project_goal"],
      "properties": {
        "notebook_path": {
          "type": "string",
          "description": "Analyst が参照した Notebook のパス"
        },
        "project_goal": {
          "type": "string",
          "description": "manager.json の project_goal（分析の方向性を決める基準）"
        }
      }
    }
  }
}