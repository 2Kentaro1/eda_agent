{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalystOutput",
  "type": "object",
  "required": ["role", "version", "content", "metadata"],
  "properties": {
    "role": {
      "type": "string",
      "enum": ["ANALYST"]
    },
    "version": {
      "type": "string"
    },
    "content": {
      "type": "object",
      "required": [
        "business_insights",
        "key_findings",
        "risks",
        "recommendations"
      ],
      "properties": {
        "business_insights": {
          "type": "array",
          "description": "Notebook の EDA 結果から得られたビジネス的洞察",
          "items": { "type": "string" }
        },
        "key_findings": {
          "type": "array",
          "description": "Notebook の EDA 結果から得られた主要な分析結果",
          "items": { "type": "string" }
        },
        "risks": {
          "type": "array",
          "description": "EDA 結果から判明したリスクや注意点",
          "items": { "type": "string" }
        },
        "recommendations": {
          "type": "array",
          "description": "次に行うべき分析・改善提案（EDA 視点）",
          "items": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "notebook_path": {
          "type": "string",
          "description": "Analyst が参照した Notebook のパス"
        }
      }
    }
  }
}