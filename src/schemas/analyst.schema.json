{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalystOutput",
  "type": "object",
  "required": ["role", "version", "content", "metadata"],
  "properties": {
    "role": { "const": "ANALYST" },
    "version": { "type": "string" },
    "content": {
      "type": "object",
      "required": [
        "business_insights",
        "key_findings",
        "risks",
        "recommendations"
      ],
      "properties": {
        "business_insights": { "type": "array", "items": { "type": "string" } },
        "key_findings": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "recommendations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["timestamp"],
      "properties": {
        "timestamp": { "type": "string" }
      }
    }
  }
}