{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EDAAgentOutput",
  "type": "object",
  "required": ["role", "version", "content"],
  "properties": {
    "role": {
      "type": "string",
      "enum": ["EDA_AGENT"]
    },
    "version": {
      "type": "string"
    },
    "content": {
      "type": "object",
      "required": ["code_snippets", "plot_snippets"],
      "properties": {
        "code_snippets": {
          "type": "object",
          "description": "実行可能な EDA コード（DataFrame を返す必要はない）",
          "additionalProperties": { "type": "string" }
        },
        "plot_snippets": {
          "type": "object",
          "description": "プロット用コード（Notebook で実行される）",
          "additionalProperties": { "type": "string" }
        },
        "eda_results": {
          "type": ["object", "null"],
          "description": "EDA_AGENT は結果を返さないため null で問題ない",
          "nullable": true
        }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}