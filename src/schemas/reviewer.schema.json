{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewerOutput",
  "type": "object",
  "required": ["role", "version", "content", "metadata"],
  "properties": {
    "role": { "const": "REVIEWER" },
    "version": { "type": "string" },
    "content": {
      "type": "object",
      "required": ["valid", "issues", "suggestions"],
      "properties": {
        "valid": { "type": "boolean" },
        "issues": { "type": "array", "items": { "type": "string" } },
        "suggestions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["reviewed_role", "timestamp"],
      "properties": {
        "reviewed_role": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    }
  }
}