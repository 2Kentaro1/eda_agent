{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ManagerOutput",
  "type": "object",
  "required": ["role", "version", "content", "metadata"],
  "properties": {
    "role": { "const": "MANAGER" },
    "version": { "type": "string" },
    "content": {
      "type": "object",
      "required": ["project_goal", "analysis_plan", "priority"],
      "properties": {
        "project_goal": { "type": "string" },
        "analysis_plan": { "type": "array", "items": { "type": "string" } },
        "priority": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["timestamp"],
      "properties": {
        "timestamp": { "type": "string" }
      }
    }
  }
}