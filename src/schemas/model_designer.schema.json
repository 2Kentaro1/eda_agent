{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ModelDesignerOutput",
  "type": "object",
  "required": ["role", "version", "content", "metadata"],
  "properties": {
    "role": { "const": "MODEL_DESIGNER" },
    "version": { "type": "string" },
    "content": {
      "type": "object",
      "required": [
        "model_type",
        "design_rationale",
        "feature_set",
        "hyperparameter_plan",
        "training_strategy"
      ],
      "properties": {
        "model_type": { "type": "string" },
        "design_rationale": { "type": "array", "items": { "type": "string" } },
        "feature_set": { "type": "array", "items": { "type": "string" } },
        "hyperparameter_plan": { "type": "object" },
        "training_strategy": { "type": "object" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["timestamp"],
      "properties": {
        "timestamp": { "type": "string" }
      }
    }
  }
}