{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ModelCoderOutput",
  "type": "object",
  "required": ["role", "version", "content", "metadata"],
  "properties": {
    "role": { "const": "MODEL_CODER" },
    "version": { "type": "string" },
    "content": {
      "type": "object",
      "required": [
        "imports",
        "data_prep_code",
        "training_code",
        "evaluation_code"
      ],
      "properties": {
        "imports": { "type": "array", "items": { "type": "string" } },
        "data_prep_code": { "type": "string" },
        "training_code": { "type": "array", "items": { "type": "string" } },
        "evaluation_code": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["timestamp"],
      "properties": {
        "timestamp": { "type": "string" }
      }
    }
  }
}